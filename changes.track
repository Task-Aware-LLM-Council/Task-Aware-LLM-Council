-            ["docker", "info"],
-            stdout=subprocess.DEVNULL,
-            stderr=subprocess.DEVNULL,
-            timeout=3,
-            check=True,
-        )
-        return True
-    except Exception:
-        return False
-
-
-def _apptainer_available() -> bool:
