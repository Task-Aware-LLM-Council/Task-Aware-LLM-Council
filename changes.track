-    import re
-
-    cleaned = re.sub(r"```(?:json)?\s*([\s\S]*?)\s*```", r"\1", response_text).strip()
-
-    def _clamp(v: float) -> float:
-        return max(1.0, min(10.0, v))
-
-    # Attempt 1: full JSON
