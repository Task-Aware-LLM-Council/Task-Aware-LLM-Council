+version = "0.1.0"
+description = "Add your description here"
+readme = "README.md"
+authors = [
+    { name = "Bhaskar Mahajan", email = "bhaskarmahajan98@gmail.com" }
+]
+requires-python = ">=3.12"
+dependencies = [
+    "common",
+    "huggingface-hub>=0.36.2",
+    "transformers>=4.52.4",
