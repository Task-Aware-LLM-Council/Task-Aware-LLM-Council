-            "--net",                 # Enables network namespace isolation
-            "--network=none",        # Explicitly disables networking
-            "--cleanenv",            # Prevents host environment variables from leaking
-            "--bind", f"{temp_dir}:/code:ro",
-            "--pwd", "/code",
