-        ("model-a", "demo_two", "http://127.0.0.1:80/model-a"),
-        ("model-b", "demo", "http://127.0.0.1:80/model-b"),
-        ("model-b", "demo", "http://127.0.0.1:80/model-b"),
-        ("model-b", "demo_two", "http://127.0.0.1:80/model-b"),
