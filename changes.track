-@pytest.fixture
-def specialist_orch() -> FakeOrchestrator:
-    return FakeOrchestrator(
-        {
-            "math_code": FakeClient("math_code"),
-            "qa_reasoning": FakeClient("qa_reasoning"),
-            "fact_general": FakeClient("fact_general"),
-        }
