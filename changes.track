+[project]
+name = "task-eval"
+version = "0.1.0"
+description = "Reusable dataset normalization and metric evaluation for benchmark tasks"
+readme = "README.md"
+authors = [
+    { name = "Bhaskar Mahajan", email = "bhaskarmahajan98@gmail.com" }
+]
+requires-python = ">=3.12"
+dependencies = [
+    "benchmarking-pipeline",
+    "datasets>=4.0.0",
+]
+
+[project.optional-dependencies]
+test = [
+    "pytest>=8.3",
+]
+
+[project.scripts]
+task-eval = "task_eval:main"
+
+[tool.pytest.ini_options]
+asyncio_mode = "auto"
+
+[tool.uv.sources]
+benchmarking-pipeline = { workspace = true }
+llm-gateway = { workspace = true }
+
+[build-system]
+requires = ["uv_build>=0.9.1,<0.10.0"]
+build-backend = "uv_build"
