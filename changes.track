-        data = json.loads(cleaned)
-        scores: dict[str, float] = {}
-        for label in valid_labels:
-            if label not in data:
-                return None
-            scores[label] = _clamp(float(data[label]["score"]))
-        return scores
-    except (json.JSONDecodeError, KeyError, TypeError, ValueError):
