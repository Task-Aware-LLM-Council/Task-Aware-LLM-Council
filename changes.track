-
-    program = f"""
-{standard_imports}
-
-{prediction}
-
-{test_code}
-
-if __name__ == "__main__":
-    check({entry_point})
-"""
-
-    with tempfile.TemporaryDirectory() as temp_dir:
-        file_path = os.path.join(temp_dir, "script.py")
-
-        with open(file_path, "w") as f:
-            f.write(program)
-
-        os.chmod(temp_dir, 0o755)
-        os.chmod(file_path, 0o644)
-
-        # docker_cmd = [
