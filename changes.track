+[project]
+name = "benchmark-runner"
+version = "0.1.0"
+description = "Top-level benchmark suite runner built on benchmarking_pipeline"
+readme = "README.md"
+authors = [
+    { name = "Bhaskar Mahajan", email = "bhaskarmahajan98@gmail.com" }
+]
+requires-python = ">=3.12"
+dependencies = [
+    "benchmarking-pipeline",
+    "llm-gateway",
+    "task-eval",
+    "datasets>=4.0.0",
+    "common",
+]
+
+[project.optional-dependencies]
+test = [
+    "pytest>=8.3",
+    "pytest-asyncio>=0.24",
+]
+
+[project.scripts]
+benchmark-runner = "benchmark_runner:main"
+
+[tool.pytest.ini_options]
+asyncio_mode = "auto"
+
+[tool.uv.sources]
+benchmarking-pipeline = { workspace = true }
+llm-gateway = { workspace = true }
+task-eval = { workspace = true }
+common = { workspace = true }
+
+[build-system]
+requires = ["uv_build>=0.9.1,<0.10.0"]
+build-backend = "uv_build"
