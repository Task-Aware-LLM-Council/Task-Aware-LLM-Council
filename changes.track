-    *,
-    batch_size: int,
-    max_cases: int | None = None,
-) -> Iterator[list[BenchmarkCase]]:
-    batch: list[BenchmarkCase] = []
-    yielded = 0
-
-    for case in source.iter_cases():
-        if max_cases is not None and yielded >= max_cases:
-            break
-
